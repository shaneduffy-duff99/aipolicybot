<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MyPoli.ai – Access Logs</title>
  <meta name="robots" content="noindex, nofollow">
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{
      min-height:100vh;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background:#0a0e1a;
      color:#f3f5f8;
      padding:32px 24px;
    }
    .wrap{ max-width:900px; margin:0 auto; }
    h1{
      font-size:1.5rem; font-weight:700;
      margin-bottom:4px; letter-spacing:-.02em;
    }
    .sub{
      color:#64748b; font-size:.9rem;
      margin-bottom:24px;
    }
    .stats{
      display:grid; grid-template-columns:repeat(auto-fit, minmax(140px, 1fr));
      gap:12px; margin-bottom:24px;
    }
    .stat{
      background:#111827;
      border:1px solid rgba(255,255,255,.08);
      border-radius:12px; padding:16px;
    }
    .stat-label{
      font-size:.72rem; color:#64748b;
      text-transform:uppercase; letter-spacing:.05em;
      margin-bottom:6px;
    }
    .stat-value{
      font-size:1.5rem; font-weight:700;
    }
    .actions{
      display:flex; gap:8px; margin-bottom:16px; flex-wrap:wrap;
    }
    .btn{
      padding:8px 14px;
      background:#1e293b;
      border:1px solid rgba(255,255,255,.08);
      border-radius:8px; color:#f3f5f8;
      font-size:.82rem; cursor:pointer;
      font-family:inherit;
    }
    .btn:hover{ background:#334155; }
    .btn.danger{ background:#450a0a; border-color:rgba(239,68,68,.2); }
    .btn.primary{ background:#4f7cff; border-color:#4f7cff; }

    table{
      width:100%; border-collapse:collapse;
      background:#111827; border-radius:12px; overflow:hidden;
      border:1px solid rgba(255,255,255,.08);
    }
    th{
      text-align:left; padding:12px 16px;
      font-size:.72rem; color:#64748b;
      text-transform:uppercase; letter-spacing:.05em;
      background:#1e293b;
      border-bottom:1px solid rgba(255,255,255,.08);
    }
    td{
      padding:12px 16px;
      font-size:.85rem;
      border-bottom:1px solid rgba(255,255,255,.05);
    }
    tr:last-child td{ border-bottom:none; }
    .code-tag{
      display:inline-block;
      padding:2px 10px; border-radius:100px;
      font-size:.7rem; font-weight:600;
      background:rgba(79,124,255,.12);
      color:#7b9fff;
      border:1px solid rgba(79,124,255,.2);
    }
    .code-tag.investor{ background:rgba(245,158,11,.12); color:#fbbf24; border-color:rgba(245,158,11,.2); }
    .code-tag.demo{ background:rgba(100,116,139,.12); color:#94a3b8; border-color:rgba(100,116,139,.2); }
    .code-tag.designpartner{ background:rgba(16,185,129,.12); color:#34d399; border-color:rgba(16,185,129,.2); }

    .empty{
      text-align:center; padding:48px;
      color:#64748b;
    }
    .empty h3{ font-size:1rem; margin-bottom:8px; color:#94a3b8; }
    .note{
      margin-top:24px; padding:16px 20px;
      background:rgba(79,124,255,.06);
      border:1px solid rgba(79,124,255,.2);
      border-radius:12px;
      font-size:.82rem; color:#94a3b8;
      line-height:1.6;
    }
    .note b{ color:#f3f5f8; }
    .note code{
      background:rgba(255,255,255,.08); padding:1px 6px;
      border-radius:4px; font-size:.78rem;
    }

    @media(max-width:600px){
      table{ font-size:.75rem; }
      th,td{ padding:10px 8px; }
      .hide-mobile{ display:none; }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <h1>Access Logs</h1>
    <p class="sub">Local log of demo access codes used on this device.</p>

    <div class="stats">
      <div class="stat">
        <div class="stat-label">Total Logins</div>
        <div class="stat-value" id="totalCount">0</div>
      </div>
      <div class="stat">
        <div class="stat-label">Investors</div>
        <div class="stat-value" id="investorCount">0</div>
      </div>
      <div class="stat">
        <div class="stat-label">Design Partners</div>
        <div class="stat-value" id="partnerCount">0</div>
      </div>
      <div class="stat">
        <div class="stat-label">Last 24h</div>
        <div class="stat-value" id="recentCount">0</div>
      </div>
    </div>

    <div class="actions">
      <button class="btn primary" onclick="refresh()">↻ Refresh</button>
      <button class="btn" onclick="exportCSV()">⬇ Export CSV</button>
      <button class="btn danger" onclick="clearLog()">✕ Clear Local Log</button>
    </div>

    <table id="logTable">
      <thead>
        <tr>
          <th>Time</th>
          <th>Code</th>
          <th>Label</th>
          <th class="hide-mobile">Referrer</th>
        </tr>
      </thead>
      <tbody id="tbody"></tbody>
    </table>

    <div class="note">
      <p style="margin-bottom:10px"><b>How tracking works:</b></p>
      <p style="margin-bottom:8px">1. <b>Local log</b> — stored in this browser's localStorage (visible here). Resets if you clear site data.</p>
      <p style="margin-bottom:8px">2. <b>Vercel Analytics</b> — if enabled, each access fires a <code>demo_access</code> event. View in Vercel Dashboard → Analytics.</p>
      <p style="margin-bottom:8px">3. <b>Image beacon</b> — pings <code>/track/access/[code]</code>. These show up as 404s in Vercel → Logs with the code name in the URL path — useful for tracking across all devices.</p>
      <p><b>Note:</b> The local log only shows accesses from this browser/device. For a full cross-device log, check Vercel Analytics or deploy a serverless function at <code>/api/log-access</code>.</p>
    </div>
  </div>

  <script>
    function getLog(){
      try {
        return JSON.parse(localStorage.getItem('mypoli_access_log') || '[]');
      } catch(e) { return []; }
    }

    function fmtTime(iso){
      const d = new Date(iso);
      return d.toLocaleString(undefined, { dateStyle:'short', timeStyle:'short' });
    }

    function codeClass(code){
      if (code === 'investor') return 'investor';
      if (code === 'demo') return 'demo';
      if (code.startsWith('designpartner')) return 'designpartner';
      return '';
    }

    function render(){
      const log = getLog().slice().reverse();
      const tbody = document.getElementById('tbody');

      if (log.length === 0){
        tbody.innerHTML = '<tr><td colspan="4" class="empty"><h3>No logins yet</h3><p>Access logs will appear here once someone enters a code.</p></td></tr>';
      } else {
        tbody.innerHTML = log.map(function(e){
          return '<tr>'
            + '<td>' + fmtTime(e.timestamp) + '</td>'
            + '<td><span class="code-tag ' + codeClass(e.codeId) + '">' + e.codeId + '</span></td>'
            + '<td>' + (e.label || '—') + '</td>'
            + '<td class="hide-mobile">' + (e.referrer || 'direct') + '</td>'
            + '</tr>';
        }).join('');
      }

      // Stats
      document.getElementById('totalCount').textContent = log.length;
      document.getElementById('investorCount').textContent = log.filter(function(e){ return e.codeId === 'investor'; }).length;
      document.getElementById('partnerCount').textContent = log.filter(function(e){ return e.codeId && e.codeId.indexOf('designpartner') === 0; }).length;

      const dayAgo = Date.now() - 24*60*60*1000;
      document.getElementById('recentCount').textContent = log.filter(function(e){
        return new Date(e.timestamp).getTime() > dayAgo;
      }).length;
    }

    function refresh(){ render(); }

    function clearLog(){
      if (confirm('Clear the local access log on this device? This cannot be undone.')) {
        localStorage.removeItem('mypoli_access_log');
        render();
      }
    }

    function exportCSV(){
      const log = getLog();
      if (log.length === 0){ alert('No logs to export.'); return; }
      const header = 'Timestamp,Code,Label,Referrer,User Agent\n';
      const rows = log.map(function(e){
        return [e.timestamp, e.codeId, e.label, e.referrer, e.userAgent]
          .map(function(v){ return '"' + String(v || '').replace(/"/g, '""') + '"'; })
          .join(',');
      }).join('\n');
      const blob = new Blob([header + rows], { type:'text/csv' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'mypoli-access-log-' + new Date().toISOString().split('T')[0] + '.csv';
      a.click();
      URL.revokeObjectURL(url);
    }

    render();
  </script>
</body>
</html>
